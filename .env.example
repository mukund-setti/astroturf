# Astroturf backend example configuration.
# Copy to .env for local development. Do not commit real values.

# Public API access. api.data.gov uses this for both regulations.gov and FCC ECFS.
DATA_GOV_API_KEY="<optional-api-data-gov-key>"
# Deprecated fallback still accepted by older scripts:
REGULATIONS_GOV_API_KEY="<optional-api-data-gov-key>"

# Local/Databricks Delta writer selection: auto | spark | delta_rs
ASTROTURF_DELTA_BACKEND="auto"

# Databricks runtime settings. Required only for live Databricks execution.
DATABRICKS_HOST="https://<databricks-workspace-host>"
DATABRICKS_TOKEN="<databricks-token>"
DATABRICKS_HTTP_PATH="/sql/1.0/warehouses/<warehouse-id>"
DATABRICKS_CATALOG="<catalog>"
DATABRICKS_SCHEMA="dev"
DATABRICKS_DATA_ROOT="/Volumes/<catalog>/<schema>/<volume-or-path>"
DATABRICKS_REPO_PATH="/Workspace/Repos/<user-or-service-principal>/astroturf"
DATABRICKS_VECTOR_INDEX_NAME="<catalog>.silver.comment_embeddings_bge_large_index"

# Optional model-provider keys. Leave unset unless you enable those modes.
ANTHROPIC_API_KEY="<optional-anthropic-key>"
OPENAI_API_KEY="<optional-openai-key>"

FEDERAL_REGISTER_API_BASE="https://www.federalregister.gov/api/v1"
LOG_LEVEL="INFO"
